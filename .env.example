# GEMINI_API_KEY: Required for Gemini AI API calls.
# This value should be provided by your deployment environment or local secrets.
# Configure it as a secret in your hosting environment.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# This value should be provided by your deployment environment at runtime.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
